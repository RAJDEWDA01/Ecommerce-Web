NODE_ENV=development
PORT=5000
LOG_LEVEL=info
# Uploads: local (default) or cloudinary
UPLOAD_DRIVER=cloudinary
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret
CLOUDINARY_FOLDER=gaumaya-uploads
MONGO_URI=mongodb://localhost:27017/gaumaya
AUDIT_LOG_RETENTION_DAYS=180
AUDIT_LOG_PRUNE_INTERVAL_MINUTES=60
AUDIT_ALERT_WINDOW_MINUTES=15
AUDIT_ALERT_MIN_EVENTS=20
AUDIT_ALERT_WARNING_FAILURE_RATE=5
AUDIT_ALERT_CRITICAL_FAILURE_RATE=15
AUDIT_ALERT_NOTIFIER_ENABLED=true
AUDIT_ALERT_WEBHOOK_URL=
AUDIT_ALERT_CHECK_INTERVAL_MINUTES=5
AUDIT_ALERT_NOTIFICATION_COOLDOWN_MINUTES=30
AUDIT_ALERT_WEBHOOK_TIMEOUT_MS=5000
CORS_ORIGIN=http://localhost:3000
TRUST_PROXY=
FRONTEND_URL=http://localhost:3000
REDIS_URL=redis://localhost:6379
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
JWT_SECRET=replace-with-strong-random-32plus-char-secret
IDEMPOTENCY_TTL_HOURS=24
IDEMPOTENCY_LOCK_SECONDS=90
PAYMENT_VERIFY_IDEMPOTENCY_TTL_HOURS=24
PAYMENT_VERIFY_IDEMPOTENCY_LOCK_SECONDS=120
ACCESS_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_DAYS=30
EMAIL_VERIFICATION_EXPIRES_HOURS=24
PASSWORD_RESET_EXPIRES_MINUTES=30
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Gaumaya Farm <no-reply@localhost>
ADMIN_NOTIFICATION_EMAILS=
ADMIN_NOTIFICATION_ORDER_ENABLED=true
ADMIN_NOTIFICATION_PAYMENT_ENABLED=true
ADMIN_NOTIFICATION_SUPPORT_ENABLED=true
ADMIN_NOTIFICATION_FEEDBACK_ENABLED=true
ADMIN_NOTIFICATION_RETRY_ENABLED=true
ADMIN_NOTIFICATION_RETRY_INTERVAL_MINUTES=5
ADMIN_NOTIFICATION_RETRY_MAX_ATTEMPTS=5
ADMIN_NOTIFICATION_RETRY_BASE_DELAY_MINUTES=10
ADMIN_NOTIFICATION_RETRY_BATCH_SIZE=20
ADMIN_NOTIFICATION_RETENTION_ENABLED=true
ADMIN_NOTIFICATION_RETENTION_DAYS=180
ADMIN_NOTIFICATION_RETENTION_INTERVAL_MINUTES=60
AUTH_LOGIN_LIMIT_MAX=5
AUTH_LOGIN_LIMIT_WINDOW_MINUTES=15
AUTH_FORGOT_PASSWORD_LIMIT_MAX=5
AUTH_FORGOT_PASSWORD_LIMIT_WINDOW_MINUTES=15
AUTH_VERIFY_RESEND_LIMIT_MAX=3
AUTH_VERIFY_RESEND_LIMIT_WINDOW_MINUTES=15
PAYMENT_CREATE_ORDER_LIMIT_MAX=15
PAYMENT_CREATE_ORDER_LIMIT_WINDOW_MINUTES=10
PAYMENT_VERIFY_LIMIT_MAX=25
PAYMENT_VERIFY_LIMIT_WINDOW_MINUTES=10
SUPPORT_TICKET_CREATE_LIMIT_MAX=15
SUPPORT_TICKET_CREATE_LIMIT_WINDOW_MINUTES=10
FEEDBACK_CREATE_LIMIT_MAX=20
FEEDBACK_CREATE_LIMIT_WINDOW_MINUTES=10
BOOTSTRAP_ADMIN_NAME=Store Admin
BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_ADMIN_PASSWORD=replace-with-strong-admin-password
