# Copy to: .env.production.compose

# Public domain for Nginx host routing
APP_DOMAIN=shop.your-domain.com

# Edge ports
PUBLIC_HTTP_PORT=80
PUBLIC_HTTPS_PORT=443

# Keep empty for same-domain API proxy via Nginx (/api -> backend)
NEXT_PUBLIC_API_BASE_URL=

# TLS cert paths inside nginx container
TLS_CERT_PATH=/etc/nginx/certs/fullchain.pem
TLS_KEY_PATH=/etc/nginx/certs/privkey.pem
